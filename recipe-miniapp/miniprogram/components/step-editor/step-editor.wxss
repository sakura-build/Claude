/* 步骤编辑组件 */
.step-editor {
  margin: 0 20rpx;
}

.step-block {
  background: var(--bg-white);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow);
}

.step-header {
  margin-bottom: 16rpx;
}

.step-num {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary);
}

.step-del {
  font-size: 24rpx;
  color: var(--danger);
}

.step-textarea {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-sm);
  padding: 16rpx;
  box-sizing: border-box;
}

.step-extra {
  margin-top: 16rpx;
  gap: 12rpx;
}

.extra-label {
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.timer-input {
  width: 120rpx;
  padding: 8rpx 16rpx;
  font-size: 26rpx;
  border-bottom: 2rpx solid var(--border-color);
  text-align: center;
}

/* 步骤图 */
.step-image-area {
  margin-top: 16rpx;
}

.step-img {
  width: 100%;
  height: 300rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-primary);
}

.step-img-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 160rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-sm);
  background: var(--bg-primary);
}

.upload-icon { font-size: 48rpx; }
.upload-text { font-size: 24rpx; color: var(--text-hint); margin-top: 8rpx; }
.img-remove {
  display: block;
  text-align: center;
  padding: 8rpx;
  font-size: 24rpx;
  color: var(--danger);
}

/* 添加步骤 */
.step-add {
  padding: 24rpx;
  color: var(--primary);
  background: var(--bg-white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 20rpx;
}

.add-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 38rpx;
  text-align: center;
  border: 2rpx dashed var(--primary);
  border-radius: 50%;
  font-size: 32rpx;
  margin-right: 10rpx;
}

.add-text { font-size: 26rpx; }
