/* ===== 全局 CSS 变量 ===== */
page {
  --primary: #FF6B35;
  --primary-light: #FF8A5C;
  --primary-dark: #E55A2B;
  --success: #4CAF50;
  --warning: #FF9800;
  --danger: #F44336;
  --info: #2196F3;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg-primary: #F5F5F5;
  --bg-white: #FFFFFF;
  --border-color: #EEEEEE;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --radius: 16rpx;
  --radius-sm: 8rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-primary);
  box-sizing: border-box;
}

/* ===== 通用工具类 ===== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 文字 */
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-hint { color: var(--text-hint); }
.text-secondary { color: var(--text-secondary); }
.text-primary { color: var(--primary); }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-bold { font-weight: bold; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--bg-white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 30rpx;
  margin: 20rpx;
}

/* ===== 通用按钮 ===== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  border: none;
  transition: all 0.2s;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-sm {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

.btn-block {
  display: flex;
  width: 100%;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.tag-primary {
  background: #FFF0E8;
  color: var(--primary);
}

.tag-success {
  background: #E8F5E9;
  color: var(--success);
}

.tag-warning {
  background: #FFF3E0;
  color: var(--warning);
}

.tag-info {
  background: #E3F2FD;
  color: var(--info);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state .empty-icon {
  font-size: 100rpx;
  color: #DDD;
}

.empty-state .empty-text {
  margin-top: 20rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}

/* ===== 浮动操作按钮 ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
  transition: all 0.2s;
}

.fab:active {
  transform: scale(0.95);
  background: var(--primary-dark);
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--bg-white);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  margin: 20rpx;
  box-shadow: var(--shadow);
}

.search-bar .search-icon {
  font-size: 32rpx;
  color: var(--text-hint);
  margin-right: 12rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
  border: none;
  outline: none;
}

/* ===== 分类筛选标签 ===== */
.category-tabs {
  display: flex;
  padding: 0 20rpx 20rpx;
  white-space: nowrap;
  overflow-x: auto;
}

.category-tabs::-webkit-scrollbar { display: none; }

.category-tab {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
  background: var(--bg-white);
  color: var(--text-secondary);
  flex-shrink: 0;
  transition: all 0.2s;
}

.category-tab.active {
  background: var(--primary);
  color: #fff;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}

/* ===== 安全区域底部 ===== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
