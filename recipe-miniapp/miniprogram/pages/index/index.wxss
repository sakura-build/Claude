/* 首页样式 */
.page-container {
  padding-bottom: 40rpx;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: var(--bg-white);
  border-radius: var(--radius);
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: var(--shadow);
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.stat-num.highlight { color: var(--primary); }
.stat-num.pending { color: var(--warning); }

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  padding: 0 20rpx;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  transition: all 0.2s;
}

.action-item:active {
  transform: scale(0.96);
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 区块 */
.section {
  margin: 20rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
}

.section-date {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 订单卡片 */
.order-card {
  margin: 0 20rpx 12rpx;
}

.order-header {
  margin-bottom: 10rpx;
}

.order-recipe {
  font-size: 30rpx;
  font-weight: bold;
}

.order-quantity {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-left: 10rpx;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.order-meta {
  gap: 6rpx;
}

.divider-dot {
  margin: 0 4rpx;
  color: var(--text-hint);
}

/* 横向菜谱滚动 */
.recipe-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.recipe-scroll-item {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  margin-right: 16rpx;
  background: var(--bg-white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
}

.recipe-thumb {
  width: 200rpx;
  height: 200rpx;
  background: var(--bg-primary);
}

.recipe-scroll-item .recipe-name {
  padding: 10rpx 12rpx 4rpx;
  font-size: 26rpx;
}

.recipe-scroll-item .recipe-category {
  padding: 0 12rpx 10rpx;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.empty-sub {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}
