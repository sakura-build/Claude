<!-- 首页仪表板 -->
<view class="page-container">
  <!-- 统计卡片区 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{stats.totalRecipes}}</text>
      <text class="stat-label">菜谱总数</text>
    </view>
    <view class="stat-card">
      <text class="stat-num highlight">{{stats.todayOrders}}</text>
      <text class="stat-label">今日点餐</text>
    </view>
    <view class="stat-card">
      <text class="stat-num pending">{{stats.pendingOrders}}</text>
      <text class="stat-label">待确认</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goShoppingList">
      <text class="action-icon">🛒</text>
      <text class="action-text">采购清单</text>
    </view>
    <view class="action-item" bindtap="goRecipes">
      <text class="action-icon">➕</text>
      <text class="action-text">添加菜谱</text>
    </view>
  </view>

  <!-- 今日订单 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📋 今日订单</text>
      <text class="section-date">{{todayDate}}</text>
    </view>

    <block wx:if="{{todayOrders.length > 0}}">
      <view class="order-card card"
        wx:for="{{todayOrders}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="onOrderTap"
      >
        <view class="order-header flex-between">
          <view class="flex-row">
            <text class="order-recipe">{{item.recipeName}}</text>
            <text class="order-quantity">x{{item.quantity}}</text>
          </view>
          <view class="order-status" style="color: {{statusColors[item.status]}}">
            {{statusLabels[item.status]}}
          </view>
        </view>
        <view class="order-meta flex-row text-secondary text-sm">
          <text>{{item.requestedBy}}</text>
          <text class="divider-dot">·</text>
          <text>{{mealLabels[item.mealType]}}</text>
          <text wx:if="{{item.note}}" class="divider-dot">·</text>
          <text wx:if="{{item.note}}" class="text-ellipsis flex-1">备注：{{item.note}}</text>
        </view>
      </view>
    </block>

    <view wx:else class="empty-state">
      <text class="empty-icon">🍳</text>
      <text class="empty-text">今天还没有点餐哦</text>
      <text class="empty-sub">去菜谱页挑选想吃的菜吧</text>
    </view>
  </view>

  <!-- 最近添加的菜谱 -->
  <view class="section" wx:if="{{recentRecipes.length > 0}}">
    <view class="section-header">
      <text class="section-title">🆕 最近新增</text>
    </view>

    <scroll-view scroll-x class="recipe-scroll">
      <view class="recipe-scroll-item"
        wx:for="{{recentRecipes}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="onRecipeTap"
      >
        <image
          class="recipe-thumb"
          src="{{item.coverImage}}"
          mode="aspectFill"
        />
        <text class="recipe-name text-ellipsis">{{item.name}}</text>
        <text class="recipe-category text-hint text-sm">{{item.category}}</text>
      </view>
    </scroll-view>
  </view>
</view>
