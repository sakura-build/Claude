<!-- 个人中心 -->
<view class="page-container">
  <!-- 用户信息 -->
  <view class="profile-header">
    <view class="avatar">👨‍🍳</view>
    <view class="user-info">
      <view class="nickname-row" bindtap="showEditNickname">
        <text class="nickname">{{nickname || '点击设置昵称'}}</text>
        <text class="edit-icon">✏️</text>
      </view>
      <text class="user-desc text-sm text-hint">家庭厨师</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-row card">
    <view class="stat-item">
      <text class="stat-num">{{stats.totalRecipes}}</text>
      <text class="stat-label">菜谱数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.totalOrders}}</text>
      <text class="stat-label">点餐次数</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-group card">
    <view class="menu-item flex-between" bindtap="goMyRecipes">
      <text>📖 我的菜谱</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item flex-between" bindtap="goShoppingList">
      <text>🛒 采购清单</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="menu-group card">
    <view class="menu-item flex-between" bindtap="showAbout">
      <text>ℹ️ 关于</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>

<!-- 昵称编辑弹窗 -->
<view class="modal-mask" wx:if="{{showNicknameEdit}}" bindtap="cancelEditNickname">
  <view class="modal-content" catchtap>
    <text class="modal-title">设置昵称</text>
    <input
      class="modal-input"
      placeholder="请输入你的昵称"
      value="{{nicknameInput}}"
      bindinput="onNicknameInput"
      maxlength="20"
      focus
    />
    <view class="modal-btns flex-between">
      <button class="btn btn-outline" bindtap="cancelEditNickname">取消</button>
      <button class="btn btn-primary" bindtap="saveNickname">保存</button>
    </view>
  </view>
</view>
