/* 菜谱编辑页样式 */
.page-container {
  padding-bottom: 60rpx;
}

/* 封面上传 */
.cover-upload {
  margin-bottom: 30rpx;
}

.cover-preview {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius);
  background: var(--bg-primary);
}

.cover-placeholder {
  width: 100%;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-primary);
  border-radius: var(--radius);
  border: 2rpx dashed var(--border-color);
}

.cover-icon { font-size: 60rpx; }
.cover-text { font-size: 26rpx; color: var(--text-hint); margin-top: 10rpx; }

/* 表单 */
.form-section {
  margin: 20rpx;
}

.form-item {
  padding: 20rpx 0;
}

.form-item + .form-item {
  border-top: 1rpx solid var(--border-color);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.form-label.required::after {
  content: ' *';
  color: var(--danger);
}

.form-input {
  width: 100%;
  padding: 14rpx 0;
  font-size: 28rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.form-textarea {
  width: 100%;
  min-height: 100rpx;
  padding: 14rpx 0;
  font-size: 28rpx;
}

.picker-value {
  padding: 14rpx 0;
  font-size: 28rpx;
  color: var(--text-primary);
}

.time-value {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: bold;
  margin-left: 16rpx;
  min-width: 100rpx;
}

/* 难度选项 */
.diff-option {
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  background: var(--bg-primary);
  margin-right: 16rpx;
  font-size: 26rpx;
  transition: all 0.2s;
}

.diff-option.active {
  background: var(--primary);
  color: #fff;
}

/* 份数步进 */
.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: var(--bg-primary);
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: bold;
}

.stepper-value {
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 30rpx;
  min-width: 40rpx;
  text-align: center;
}

/* 标签输入 */
.tag-input-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: #FFF0E8;
  color: var(--primary);
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.tag-remove {
  margin-left: 8rpx;
  font-size: 20rpx;
  opacity: 0.6;
}

.ml-10 { margin-left: 10rpx; }

/* 区块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin: 30rpx 20rpx 16rpx;
}

/* 保存区 */
.save-area {
  padding: 30rpx 20rpx;
}
